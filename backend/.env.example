NODE_ENV=production
PORT=2053

DATABASE_URL=postgresql://postgres:your_password@postgres:5432/ai_key

JWT_SECRET=change_me_min_32_chars

# Comma-separated list of allowed origins (production CORS whitelist)
# Example: https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGINS=

# 9router
NINE_ROUTER_URL=http://103.172.78.21:20128/
NINE_ROUTER_PASSWORD=change_me

# VietQR — thông tin tài khoản nhận thanh toán
VIETQR_BANK_ID=TECHCOMBANK
VIETQR_ACCOUNT_NO=your_account_number
VIETQR_ACCOUNT_NAME=YOUR NAME

# Resend — gửi email
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM=noreply@yourdomain.com

# Google reCAPTCHA v3 — lấy tại https://www.google.com/recaptcha/admin
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key
